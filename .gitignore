# =============================================================================
# 虚拟男装智能穿搭系统 - Gitignore 配置
# =============================================================================

# -----------------------------------------------------------------------------
# Python 缓存与编译文件
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.pyc
*.egg-info/
*.egg
dist/
build/
*.whl

# Python 虚拟环境
.venv/
venv/
env/
.env/

# -----------------------------------------------------------------------------
# Node.js 依赖
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# 前端构建产物
# -----------------------------------------------------------------------------
frontend/dist/
frontend/build/
frontend/node_modules/
out/
.next/
.nuxt/
.cache/

# -----------------------------------------------------------------------------
# 敏感配置文件 - 绝不能提交
# -----------------------------------------------------------------------------
# 环境变量文件（包含数据库密码、API密钥等）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 密钥文件
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# -----------------------------------------------------------------------------
# IDE 配置
# -----------------------------------------------------------------------------
.idea/
.vscode/
.vscode-test/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.user
*.iml

# -----------------------------------------------------------------------------
# 操作系统文件
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 临时文件与日志
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log
logs/
*.swp
*.swo
*~
crash.log
error.log
csp-reports.log

# -----------------------------------------------------------------------------
# 数据库文件
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.fdb

# -----------------------------------------------------------------------------
# 上传与缓存目录
# -----------------------------------------------------------------------------
uploads/
public/uploads/
*.uploads/
node-server/uploads/
node-server/public/uploads/
node-server/assets/wardrobe/thumbs/
checkpoints/
backup_*/
*.backup

# -----------------------------------------------------------------------------
# 3D模型与大型资源文件（按需配置）
# -----------------------------------------------------------------------------
# models/3d/large_models/
# data/user_clothes/*.jpg
# data/user_clothes/*.png

# -----------------------------------------------------------------------------
# 测试覆盖率报告
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# 快捷方式文件
# -----------------------------------------------------------------------------
*.lnk

# -----------------------------------------------------------------------------
# 部署相关（按需配置）
# -----------------------------------------------------------------------------
deploy.sh.bak
rollback.sh.bak
*.service.bak

# -----------------------------------------------------------------------------
# 科学计算相关（按需配置）
# -----------------------------------------------------------------------------
pytorch3d-*/
pifuhd-main/

# -----------------------------------------------------------------------------
# Terraform状态（如果使用）
# -----------------------------------------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
