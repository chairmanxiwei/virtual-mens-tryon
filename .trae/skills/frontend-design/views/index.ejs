<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="基于Node.js的动态前端开发工具，支持响应式设计和实时预览">
  <meta name="keywords" content="前端设计,Node.js,响应式,动态前端,API集成">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <% include partials/header.ejs %>
  
  <main>
    <!-- 英雄区域 -->
    <section class="hero" aria-label="主页英雄区域">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title"><%= message %></h1>
          <p class="hero-description">基于Node.js的动态前端开发工具，支持响应式设计和实时预览，为您的项目提供现代化的开发体验。</p>
          <div class="cta-buttons">
            <a href="/about" class="btn btn-primary" role="button">了解更多</a>
            <a href="#features" class="btn btn-secondary" role="button">查看功能</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-animation">
            <div class="animation-element"></div>
            <div class="animation-element"></div>
            <div class="animation-element"></div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- 特性区域 -->
    <section id="features" class="features" aria-label="核心功能">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">核心功能</h2>
          <p class="section-description">我们提供全面的前端开发工具，帮助您构建现代化的Web应用</p>
        </div>
        <div class="features-grid">
          <article class="feature-card" role="article">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
            </div>
            <h3 class="feature-title">动态前端开发</h3>
            <p class="feature-description">基于Node.js的服务器端渲染，实时数据交互和API集成，为您的应用提供流畅的用户体验。</p>
          </article>
          <article class="feature-card" role="article">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <h3 class="feature-title">响应式设计</h3>
            <p class="feature-description">适配不同设备屏幕尺寸，移动优先的设计理念，确保您的应用在任何设备上都能完美展示。</p>
          </article>
          <article class="feature-card" role="article">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
            </div>
            <h3 class="feature-title">组件化开发</h3>
            <p class="feature-description">可重用的UI组件，模块化代码结构，提高开发效率和代码质量，让您的项目更加易于维护。</p>
          </article>
          <article class="feature-card" role="article">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 4 23 10 17 10"></polyline>
                <polyline points="1 20 1 14 7 14"></polyline>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
              </svg>
            </div>
            <h3 class="feature-title">实时预览</h3>
            <p class="feature-description">开发时的热重载，即时看到代码更改效果，加速开发流程，让您的创意快速变为现实。</p>
          </article>
        </div>
      </div>
    </section>
    
    <!-- API示例区域 -->
    <section class="api-demo" aria-label="API示例">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">API示例</h2>
          <p class="section-description">体验我们的API功能，了解如何与后端服务集成</p>
        </div>
        <div class="api-container">
          <div id="api-data" class="api-result" role="region" aria-live="polite">加载中...</div>
          <div class="api-code-snippet">
            <pre><code>fetch('/api/data')
  .then(response => response.json())
  .then(data => console.log(data))
  .catch(error => console.error(error));</code></pre>
          </div>
        </div>
      </div>
    </section>
    
    <!-- 联系区域 -->
    <section class="contact" aria-label="联系我们">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">联系我们</h2>
          <p class="section-description">如有任何问题或建议，欢迎随时与我们联系</p>
        </div>
        <div class="contact-content">
          <div class="contact-form-container">
            <form id="contact-form" class="contact-form" method="POST" action="/api/submit" novalidate>
              <div class="form-group">
                <label for="name" class="form-label">姓名</label>
                <input type="text" id="name" name="name" class="form-input" required aria-required="true">
                <div class="form-error" aria-live="polite"></div>
              </div>
              <div class="form-group">
                <label for="email" class="form-label">邮箱</label>
                <input type="email" id="email" name="email" class="form-input" required aria-required="true">
                <div class="form-error" aria-live="polite"></div>
              </div>
              <div class="form-group">
                <label for="message" class="form-label">留言</label>
                <textarea id="message" name="message" rows="4" class="form-textarea" required aria-required="true"></textarea>
                <div class="form-error" aria-live="polite"></div>
              </div>
              <button type="submit" class="btn btn-primary form-submit" role="button">提交</button>
            </form>
            <div id="form-result" class="form-result" role="status" aria-live="polite"></div>
          </div>
          <div class="contact-info">
            <div class="info-item">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div class="info-content">
                <h4>邮箱</h4>
                <p>contact@frontend-skill.com</p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
              </div>
              <div class="info-content">
                <h4>电话</h4>
                <p>123-456-7890</p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div class="info-content">
                <h4>地址</h4>
                <p>北京市朝阳区科技园区</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <% include partials/footer.ejs %>
  <script src="/public/js/main.js"></script>
  <script>
    // 页面加载完成后初始化动画
    document.addEventListener('DOMContentLoaded', function() {
      // 英雄区域动画
      const heroTitle = document.querySelector('.hero-title');
      if (heroTitle) {
        heroTitle.classList.add('animate-in');
      }
      
      // 特性卡片动画
      const featureCards = document.querySelectorAll('.feature-card');
      featureCards.forEach((card, index) => {
        setTimeout(() => {
          card.classList.add('animate-in');
        }, index * 100);
      });
    });
  </script>
</body>
</html>