<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/renaissance-style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <nav class="nav-overlay">
        <div class="brand">虚拟男装</div>
    </nav>

    <div class="login-container">
        <div class="login-card">
            <div class="form-header">
                <h1>绅士入口</h1>
                <p>登录您的专属商务形象管理系统</p>
            </div>

            <% if (error) { %>
            <div style="color: var(--accent-red); margin-bottom: 1rem; text-align: center;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">邮箱地址</label>
                    <input type="email" id="email" name="email" placeholder="请输入您的邮箱" required>
                </div>
                <div class="form-group">
                    <label for="password">密码</label>
                    <input type="password" id="password" name="password" placeholder="请输入您的密码" required>
                </div>
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-sign-in-alt"></i> 登录
                </button>
                <!-- 注册按钮改为普通的 a 链接，避免内联事件被 CSP 阻止 -->
                <a href="/register" class="btn btn-secondary btn-block">
                    <i class="fas fa-user-plus"></i> 注册新账户
                </a>
            </form>

            <div style="margin-top: 2rem; text-align: center; font-size: 0.8rem; color: rgba(240,240,240,0.3);">
                <p>测试账户：admin@example.com / admin123</p>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="/js/artistic-animations.js"></script>
    <script src="/js/advanced-script.js"></script>
    <script src="/js/login.js" defer></script>
</body>
    </html>