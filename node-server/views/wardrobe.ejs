<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/renaissance-style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <nav class="nav-overlay">
        <div class="brand">虚拟男装</div>
        <div class="nav-links">
            <a href="/dashboard" class="nav-item">首页</a>
            <a href="/wardrobe" class="nav-item">衣橱</a>
            <a href="/ai-outfit" class="nav-item">AI搭配</a>
            <a href="/virtual-tryon" class="nav-item">虚拟试穿</a>
            <a href="/logout" class="nav-item">登出</a>
        </div>
    </nav>

    <section>
        <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
            <div class="hero" style="min-height: 30vh; padding-top: 10vh;">
                <h1 class="hero-title reveal-text">
                    <span>我的衣橱</span>
                </h1>
                <p class="hero-subtitle">管理您的个人服装收藏，打造完美造型</p>
            </div>
            
            <!-- 消息提示 -->
            <% if (locals.uploadSuccess) { %>
            <div style="background: rgba(0, 255, 0, 0.1); border: 1px solid #4CAF50; color: #4CAF50; padding: 1rem; margin-bottom: 2rem; border-radius: 4px;">
                <i class="fas fa-check-circle"></i> <%= uploadSuccess %>
            </div>
            <% } %>
            <% if (locals.uploadError) { %>
            <div style="background: rgba(255, 0, 0, 0.1); border: 1px solid #f44336; color: #f44336; padding: 1rem; margin-bottom: 2rem; border-radius: 4px;">
                <i class="fas fa-exclamation-circle"></i> <%= uploadError %>
            </div>
            <% } %>

            <!-- Stats & Actions -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; flex-wrap: wrap; gap: 2rem;">
                <div style="display: flex; gap: 2rem;">
                    <div class="stat-item" style="text-align: left;">
                        <span class="stat-number" style="font-size: 3rem;" data-value="<%= clothes.length %>"><%= clothes.length %></span>
                        <span class="stat-label">总衣物</span>
                    </div>
                    <div class="stat-item" style="text-align: left;">
                        <span class="stat-number" style="font-size: 3rem;" data-value="<%= [...new Set(clothes.map(c => c.type))].length %>"><%= [...new Set(clothes.map(c => c.type))].length %></span>
                        <span class="stat-label">类型</span>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button class="btn btn-primary" onclick="openUploadModal()">
                        <i class="fas fa-plus"></i> 上传新衣物
                    </button>
                    <button class="btn btn-secondary" onclick="generateAllOutfits()">
                        <i class="fas fa-magic"></i> 生成搭配
                    </button>
                </div>
            </div>

            <!-- Filter -->
            <div style="margin-bottom: 2rem; border-bottom: 1px solid rgba(240,240,240,0.1); padding-bottom: 1rem;">
                <span style="margin-right: 1rem; color: var(--accent-gold); text-transform: uppercase; letter-spacing: 0.1em;">筛选:</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('all')">全部</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('上装')">上装</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('下装')">下装</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('外套')">外套</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('鞋子')">鞋子</span>
                <span class="nav-item" style="margin-right: 1.5rem; cursor: pointer;" onclick="filterByType('配件')">配件</span>
            </div>

            <!-- Grid -->
            <% if (clothes.length === 0) { %>
            <div style="text-align: center; padding: 4rem; border: 1px dashed rgba(240,240,240,0.2);">
                <i class="fas fa-wardrobe" style="font-size: 3rem; color: rgba(240,240,240,0.3); margin-bottom: 1rem;"></i>
                <h3 style="color: rgba(240,240,240,0.5);">衣橱还是空的</h3>
                <button class="btn btn-primary" style="margin-top: 1rem;" onclick="openUploadModal()">上传第一件衣物</button>
            </div>
            <% } else { %>
            <div class="clothing-grid">
                <% clothes.forEach(cloth => { %>
                <div class="clothing-card" data-type="<%= cloth.type %>" data-id="<%= cloth.id %>">
                    <div class="clothing-card-image" style="position: relative; overflow: hidden;">
                        <!-- 使用 cloth.image，如果加载失败则显示占位图 -->
                        <img src="<%= cloth.image %>" alt="<%= cloth.name %>" 
                             onerror="this.onerror=null; this.src='/img/placeholder.svg';" 
                             style="width: 100%; height: 100%; object-fit: cover;">
                        <!-- 调试：可在页面查看图片路径（隐藏） -->
                        <!-- 图片路径：<%= cloth.image %> -->
                        <div style="position: absolute; bottom: 0; left: 0; width: 100%; padding: 1rem; background: rgba(15,15,15,0.8); display: flex; justify-content: space-around; transform: translateY(100%); transition: transform 0.3s ease;" class="card-actions">
                            <i class="fas fa-magic" onclick="generateRecommendations('<%= cloth.id %>')" style="color: var(--accent-gold); cursor: pointer;"></i>
                            <i class="fas fa-edit" onclick="editCloth('<%= cloth.id %>')" style="color: #fff; cursor: pointer;"></i>
                            <i class="fas fa-trash" onclick="deleteCloth('<%= cloth.id %>')" style="color: var(--accent-red); cursor: pointer;"></i>
                        </div>
                    </div>
                    <div class="clothing-card-info">
                        <h3><%= cloth.name %></h3>
                        <div class="clothing-meta">
                            <span><%= cloth.type %></span>
                            <% if (cloth.primary_color_name) { %>
                                <span><%= cloth.primary_color_name %><% if (cloth.primary_color_pct !== null && cloth.primary_color_pct !== undefined) { %>(<%= cloth.primary_color_pct %>%)<% } %><% if (cloth.secondary_color_name) { %> / <%= cloth.secondary_color_name %><% if (cloth.secondary_color_pct !== null && cloth.secondary_color_pct !== undefined) { %>(<%= cloth.secondary_color_pct %>%)<% } %><% } %></span>
                            <% } else { %>
                                <span><%= cloth.color %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } %>
        </div>
    </section>

    <!-- Upload Modal -->
<div id="upload-modal" class="upload-modal">
    <div class="upload-modal-content">
        <div style="position: relative; padding: 2rem 0;">
            <h3 style="text-align: center; margin: 0 0 2rem 0; font-family: var(--font-body); font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-gold); font-weight: 600;">上传新衣物</h3>
            <button onclick="closeUploadModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; transition: color 0.3s ease; padding: 0.5rem;">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <form action="/wardrobe/upload" method="POST" id="cloth-upload-form" enctype="multipart/form-data">
            <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
            
            <div class="upload-zone" id="upload-zone">
                <input type="file" id="cloth-photo" name="photo" accept="image/jpeg,image/png,image/jpg" style="display: none;">
                <i class="fas fa-cloud-upload-alt"></i>
                <p>点击或拖拽文件到此处上传</p>
                <small style="color: rgba(240,240,240,0.5);">支持 JPEG, PNG 格式（可选）</small>
            </div>
            
            <div id="file-preview" style="display: none; margin-bottom: 1rem; text-align: center;">
                <img id="preview-image" src="" alt="预览图片" style="max-height: 200px; border: 1px solid var(--accent-gold);">
            </div>
            
            <!-- 衣物名称 -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="name">衣物名称</label>
                <input type="text" id="name" name="name" placeholder="例如：白色衬衫" required>
            </div>
            
            <!-- 第一行：颜色、类型 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="color">颜色</label>
                    <input type="text" id="color" name="color" placeholder="请输入衣物颜色" required>
                </div>
                <div class="form-group">
                    <label for="type">类型</label>
                    <select id="type" name="type" required>
                        <option value="上装">上装</option>
                        <option value="下装">下装</option>
                        <option value="外套">外套</option>
                        <option value="鞋子">鞋子</option>
                        <option value="配件">配件</option>
                    </select>
                </div>
            </div>
            
            <!-- 第二行：风格、图案 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="style">风格</label>
                    <select id="style" name="style" required>
                        <option value="">请选择</option>
                        <option value="休闲">休闲</option>
                        <option value="通勤">通勤</option>
                        <option value="运动">运动</option>
                        <option value="正式">正式</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="pattern">图案</label>
                    <select id="pattern" name="pattern" required>
                        <option value="">请选择图案</option>
                        <option value="纯色">纯色</option>
                        <option value="条纹">条纹</option>
                        <option value="格纹">格纹</option>
                        <option value="印花">印花</option>
                        <option value="图案">图案</option>
                    </select>
                </div>
            </div>
            
            <!-- 第三行：尺码、季节 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="size">尺码</label>
                    <select id="size" name="size" style="border-radius: 0; border: 1px solid rgba(240,240,240,0.2); background-color: #0f0f0f; color: var(--text-color); padding: 1rem;">
                        <option value="">请选择尺码</option>
                        <option value="XS">XS</option>
                        <option value="S">S</option>
                        <option value="M">M</option>
                        <option value="L">L</option>
                        <option value="XL">XL</option>
                        <option value="XXL">XXL</option>
                        <option value="XXXL">XXXL</option>
                        <option value="均码">均码</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="season">季节</label>
                    <select id="season" name="season" required>
                        <option value="">请选择</option>
                        <option value="春">春</option>
                        <option value="夏">夏</option>
                        <option value="秋">秋</option>
                        <option value="冬">冬</option>
                        <option value="四季">四季</option>
                    </select>
                </div>
            </div>
            
            <!-- 第四行：品牌、材质（下拉选择） -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="brand">品牌</label>
                    <input type="text" id="brand" name="brand" placeholder="例如：优衣库" value="未知">
                </div>
                <div class="form-group">
                    <label for="material">材质</label>
                    <select id="material" name="material" required>
                        <option value="">请选择</option>
                        <option value="棉">棉</option>
                        <option value="羽绒">羽绒</option>
                        <option value="涤纶">涤纶</option>
                        <option value="羊毛">羊毛</option>
                    </select>
                </div>
            </div>
            
            <!-- 第五行：价格（新增） -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="price">价格 (元)</label>
                <input type="number" step="0.01" id="price" name="price" placeholder="0.00" value="0.00">
            </div>
            
            <!-- 第六行：适合温度范围（新增） -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="suitable_temp">适合温度范围</label>
                <select id="suitable_temp" name="suitable_temp" required>
                    <option value="">请选择</option>
                    <option value="0-10℃">0-10℃（寒冬）</option>
                    <option value="10-20℃">10-20℃（春秋）</option>
                    <option value="20-30℃">20-30℃（夏季）</option>
                    <option value="30℃以上">30℃以上（酷暑）</option>
                </select>
            </div>
            
            <div class="form-group" style="margin-top: 1rem;">
                <label for="description">描述</label>
                <textarea id="description" name="description" placeholder="请输入衣物描述" rows="2"></textarea>
            </div>

            <div id="recognition-result" style="display: none; background: rgba(255,255,255,0.05); padding: 1rem; margin-bottom: 1rem;">
                <h4 style="color: var(--accent-gold); margin-bottom: 0.5rem;"><i class="fas fa-robot"></i> 智能识别</h4>
                <p id="rec-text" style="font-size: 0.8rem;"></p>
                <button type="button" id="apply-recognition" class="btn btn-secondary" style="width: 100%; margin-top: 0.5rem; font-size: 0.7rem;">应用识别结果</button>
            </div>
            
            <!-- 固定底部按钮 -->
            <div style="display: flex; gap: 1rem; margin-top: 2rem; position: sticky; bottom: 0; background: #111; padding-top: 1rem; border-top: 1px solid rgba(240,240,240,0.1); z-index: 5;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">上传</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeUploadModal()">取消</button>
            </div>
        </form>
    </div>
</div>
    
    <!-- Edit Modal -->
<div id="edit-modal" class="upload-modal" data-lenis-prevent>
    <div class="upload-modal-content" data-lenis-prevent style="max-height: 80vh; overflow-y: auto; position: relative;">
        <!-- 固定头部 -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; position: sticky; top: 0; background: #111; padding-bottom: 1rem; border-bottom: 1px solid rgba(240,240,240,0.1); z-index: 10;">
            <h3>编辑衣物</h3>
            <button onclick="closeEditModal()" style="background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer;">&times;</button>
        </div>
        
        <form action="/wardrobe/edit" method="POST" id="cloth-edit-form">
            <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
            <input type="hidden" name="id" id="edit-id">
            
            <!-- 衣物名称 -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="edit-name">衣物名称</label>
                <input type="text" id="edit-name" name="name" placeholder="例如：白色衬衫" required>
            </div>
            
            <!-- 第一行：颜色、类型 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="edit-color">颜色</label>
                    <input type="text" id="edit-color" name="color" placeholder="请输入衣物颜色" required>
                </div>
                <div class="form-group">
                    <label for="edit-type">类型</label>
                    <select id="edit-type" name="type" required>
                        <option value="上装">上装</option>
                        <option value="下装">下装</option>
                        <option value="外套">外套</option>
                        <option value="鞋子">鞋子</option>
                        <option value="配件">配件</option>
                    </select>
                </div>
            </div>
            
            <!-- 第二行：风格、图案 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="edit-style">风格</label>
                    <select id="edit-style" name="style" required>
                        <option value="">请选择</option>
                        <option value="休闲">休闲</option>
                        <option value="通勤">通勤</option>
                        <option value="运动">运动</option>
                        <option value="正式">正式</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="edit-pattern">图案</label>
                    <select id="edit-pattern" name="pattern" required>
                        <option value="">请选择图案</option>
                        <option value="纯色">纯色</option>
                        <option value="条纹">条纹</option>
                        <option value="格纹">格纹</option>
                        <option value="印花">印花</option>
                        <option value="图案">图案</option>
                    </select>
                </div>
            </div>
            
            <!-- 第三行：尺码、季节 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="edit-size">尺码</label>
                    <select id="edit-size" name="size" style="border-radius: 0; border: 1px solid rgba(240,240,240,0.2); background-color: #0f0f0f; color: var(--text-color); padding: 1rem;">
                        <option value="">请选择尺码</option>
                        <option value="XS">XS</option>
                        <option value="S">S</option>
                        <option value="M">M</option>
                        <option value="L">L</option>
                        <option value="XL">XL</option>
                        <option value="XXL">XXL</option>
                        <option value="XXXL">XXXL</option>
                        <option value="均码">均码</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="edit-season">季节</label>
                    <select id="edit-season" name="season" required>
                        <option value="">请选择</option>
                        <option value="春">春</option>
                        <option value="夏">夏</option>
                        <option value="秋">秋</option>
                        <option value="冬">冬</option>
                        <option value="四季">四季</option>
                    </select>
                </div>
            </div>
            
            <!-- 第四行：品牌、材质（新增） -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label for="edit-brand">品牌</label>
                    <input type="text" id="edit-brand" name="brand" placeholder="例如：优衣库">
                </div>
                <div class="form-group">
                    <label for="edit-material">材质</label>
                    <select id="edit-material" name="material" required>
                        <option value="">请选择</option>
                        <option value="棉">棉</option>
                        <option value="羽绒">羽绒</option>
                        <option value="涤纶">涤纶</option>
                        <option value="羊毛">羊毛</option>
                    </select>
                </div>
            </div>
            
            <!-- 第五行：价格（新增） -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="edit-price">价格 (元)</label>
                <input type="number" step="0.01" id="edit-price" name="price" placeholder="0.00">
            </div>
            
            <!-- 第六行：适合温度范围（新增） -->
            <div class="form-group" style="margin-top: 1rem;">
                <label for="edit-suitable_temp">适合温度范围</label>
                <select id="edit-suitable_temp" name="suitable_temp" required>
                    <option value="">请选择</option>
                    <option value="0-10℃">0-10℃（寒冬）</option>
                    <option value="10-20℃">10-20℃（春秋）</option>
                    <option value="20-30℃">20-30℃（夏季）</option>
                    <option value="30℃以上">30℃以上（酷暑）</option>
                </select>
            </div>
            
            <div class="form-group" style="margin-top: 1rem;">
                <label for="edit-description">描述</label>
                <textarea id="edit-description" name="description" placeholder="请输入衣物描述" rows="2"></textarea>
            </div>
            
            <!-- 固定底部按钮 -->
            <div style="display: flex; gap: 1rem; margin-top: 2rem; position: sticky; bottom: 0; background: #111; padding-top: 1rem; border-top: 1px solid rgba(240,240,240,0.1); z-index: 5;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">保存更改</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeEditModal()">取消</button>
            </div>
        </form>
    </div>
</div>

    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="/js/artistic-animations.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/advanced-script.js"></script>
    <script src="/js/wardrobe.js"></script>
</body>
</html>
