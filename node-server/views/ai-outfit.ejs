        const _missingImagePollers = new Map();

        function buildTaobaoSearchUrl(keyword) {
            const q = (keyword || '').toString().trim();
            return `https://s.taobao.com/search?q=${encodeURIComponent(q)}`;
        }

        function escapeHtmlAttr(value) {
            return String(value || '')
                .replaceAll('&', '&amp;')
                .replaceAll('"', '&quot;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;');
        }

        function sendTaobaoClickMetric(keyword, category, source) {
            const payload = JSON.stringify({ taobaoKeyword: keyword, category, source });
            const url = `${API_BASE}/api/metrics/taobao-click`;
            try {
                if (navigator.sendBeacon) {
                    navigator.sendBeacon(url, new Blob([payload], { type: 'application/json' }));
                    return;
                }
            } catch (e) {}
            fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include', body: payload, keepalive: true }).catch(() => {});
        }

        function showTopNotice(message) {
            let bar = document.getElementById('top-notice');
            if (!bar) {
                bar = document.createElement('div');
                bar.id = 'top-notice';
                bar.style.position = 'fixed';
                bar.style.top = '0';
                bar.style.left = '0';
                bar.style.right = '0';
                bar.style.zIndex = '9999';
                bar.style.padding = '10px 14px';
                bar.style.background = 'rgba(114, 47, 55, 0.92)';
                bar.style.color = '#fff';
                bar.style.fontWeight = '700';
                bar.style.fontSize = '14px';
                bar.style.display = 'none';
                document.body.appendChild(bar);
            }
            bar.textContent = message;
            bar.style.display = 'block';
            clearTimeout(bar._t);
            bar._t = setTimeout(() => { bar.style.display = 'none'; }, 5000);
        }

        function startMissingImagePoll(taskId, imgEl, keyword) {
            if (!taskId || _missingImagePollers.has(taskId)) return;
            let tries = 0;
            const maxTries = 40;
            const timer = setInterval(async () => {
                tries += 1;
                if (tries > maxTries) {
                    clearInterval(timer);
                    _missingImagePollers.delete(taskId);
                    // 隐藏加载动画
                    const loadingEl = imgEl.closest('div').querySelector('.image-loading');
                    if (loadingEl) loadingEl.style.display = 'none';
                    return;
                }
                try {
                    const resp = await fetch(`${API_BASE}/api/missing-item/image/task/${taskId}`, { credentials: 'include' });
                    const j = await resp.json().catch(() => ({}));
                    const data = j && j.data ? j.data : {};
                    if (!j.success) return;
                    if (data.status === 'completed' && data.imageUrl) {
                        imgEl.src = data.imageUrl;
                        // 隐藏加载动画
                        const loadingEl = imgEl.closest('div').querySelector('.image-loading');
                        if (loadingEl) loadingEl.style.display = 'none';
                        clearInterval(timer);
                        _missingImagePollers.delete(taskId);
                        return;
                    }
                    if (data.status === 'failed') {
                        // 隐藏加载动画
                        const loadingEl = imgEl.closest('div').querySelector('.image-loading');
                        if (loadingEl) loadingEl.style.display = 'none';
                        clearInterval(timer);
                        _missingImagePollers.delete(taskId);
                        if (keyword) showTopNotice(`该单品暂无法生成图片，请手动在淘宝搜索关键词：${keyword}`);
                        return;
                    }
                } catch (e) {
                    console.error('图片生成轮询失败:', e);
                }
            }, 1500);
            _missingImagePollers.set(taskId, timer);
        }

        document.addEventListener('click', function(e) {
            const a = e.target && e.target.closest ? e.target.closest('a[data-taobao-keyword]') : null;
            if (!a) return;
            const keyword = a.getAttribute('data-taobao-keyword') || '';
            const category = a.getAttribute('data-category') || '';
            const source = a.getAttribute('data-source') || '';
            if (keyword) sendTaobaoClickMetric(keyword, category, source);
        }, true);
        
