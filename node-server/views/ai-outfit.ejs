        // 生成穿搭推荐（调用大模型）
        document.getElementById('recommend-btn').addEventListener('click', async function() {
            // 校验前置条件
            if (!weatherData) {
                document.getElementById('recommend-error').textContent = '请先查询天气';
                document.getElementById('recommend-error').style.display = 'block';
                return;
            }
            
            if (!Array.isArray(wardrobeData) || wardrobeData.length === 0) {
                document.getElementById('recommend-error').textContent = '衣橱数据加载失败，请刷新页面';
                document.getElementById('recommend-error').style.display = 'block';
                return;
            }
            
            const scene = document.getElementById('scene-select').value;
            const purpose = document.getElementById('purpose-select').value;
            const style = document.getElementById('style-select').value;
            
            if (!scene || !purpose || !style) {
                document.getElementById('recommend-error').textContent = '请选择完整的场景、目的和风格偏好';
                document.getElementById('recommend-error').style.display = 'block';
                return;
            }
            
            document.getElementById('recommend-error').style.display = 'none';
            document.getElementById('recommend-loading').style.display = 'block';
            
            try {
                const response = await fetch(`${API_BASE}/api/outfit/recommend`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        scene,
                        tempC: weatherData.temperature,
                        weather_type: weatherData.weather_type || weatherData.weather || '',
                        purpose,
                        style
                    })
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                if (result && result.success) {
                    recommendData = (result.data && typeof result.data === 'object') ? result.data : {};
                    
                    // 处理3套方案
                    const outfits = (recommendData && recommendData.outfits && Array.isArray(recommendData.outfits)) ? recommendData.outfits
                        : (result.outfits && Array.isArray(result.outfits)) ? result.outfits
                        : [];
                    
                    const normalizedOutfits = normalizeOutfits(outfits, recommendData, result);
                    recommendData.outfits = normalizedOutfits;
                    recommendData.selected_items = normalizedOutfits[0] ? normalizedOutfits[0].selected_items : [];
                    renderOutfitPlans(normalizedOutfits);
                    
                    // 处理需补充的衣物
                    if (recommendData.missing_items && recommendData.missing_items.length > 0) {
                        const missingText = recommendData.missing_items.map(item => {
                            if (item.suggestion) {
                                return item.suggestion;
                            } else {
                                const type = item.type || '';
                                const example = item.example || item.name || '';
                                const reason = item.reason || '';
                                if (type && example) {
                                    return `缺失${type}：示例「${example}」，理由：${reason || '建议补齐该类别以完善整体搭配'}`;
                                }
                                if (type) {
                                    return `缺失${type}：${reason || '建议补齐该类别以完善整体搭配'}`;
                                }
                                return reason || '建议补齐缺失单品以完善整体搭配';
                            }
                        }).join('；');
                        document.getElementById('missing-text').textContent = missingText;
                        document.getElementById('missing-text').style.color = '#f0f0f0';
                        document.getElementById('missing-text').style.fontSize = '1rem';
                        document.getElementById('missing-text').style.lineHeight = '1.6';
                        // 只渲染前3个缺失单品
                        const limitedMissingItems = (recommendData.missing_items || []).slice(0, 3);
                        renderMissingTypeCards(limitedMissingItems);
                        document.getElementById('missing-items').style.display = 'block';
                    } else {
                        // 当没有缺失单品时，显示固定提示信息
                        document.getElementById('missing-text').textContent = '没有缺失任何服装';
                        document.getElementById('missing-text').style.color = '#f0f0f0';
                        document.getElementById('missing-text').style.fontSize = '1rem';
                        document.getElementById('missing-text').style.lineHeight = '1.6';
                        renderMissingTypeCards([]);
                        document.getElementById('missing-items').style.display = 'block';
                    }
                    
                    document.getElementById('recommend-result').style.display = 'block';
                    console.log('穿搭推荐生成成功（大模型）:', recommendData);
                } else {
                    const msg = (result && (result.error || result.message)) || '生成推荐失败';
                    document.getElementById('recommend-error').textContent = msg;
                    document.getElementById('recommend-error').style.display = 'block';
                    console.error('生成推荐失败:', result);
                }
            } catch (error) {
                document.getElementById('recommend-error').textContent = '生成推荐失败，请稍后重试';
                document.getElementById('recommend-error').style.display = 'block';
                console.error('生成推荐异常:', error);
            } finally {
                document.getElementById('recommend-loading').style.display = 'none';
            }
        });

        function normalizeOutfits(outfits, recommendData, result) {
            const safe = Array.isArray(outfits) ? outfits : [];
            const fallbackReason = (recommendData && recommendData.reason) || result.reason || '暂无搭配理由';
            const fallbackItems = (result.selected_items && Array.isArray(result.selected_items)) ? result.selected_items
                : (recommendData && Array.isArray(recommendData.selected_items)) ? recommendData.selected_items
                : [];
            const normalized = safe
                .slice(0, 3)
                .map((o, idx) => ({
                    title: o.title || `方案${idx + 1}`,
                    reason: (o.reason || '').trim() || fallbackReason,
                    selected_items: Array.isArray(o.selected_items) ? o.selected_items : fallbackItems
                }));
            while (normalized.length < 3) {
                normalized.push({
                    title: `方案${normalized.length + 1}`,
                    reason: fallbackReason,
                    selected_items: fallbackItems
                });
            }
            return normalized;
        }

