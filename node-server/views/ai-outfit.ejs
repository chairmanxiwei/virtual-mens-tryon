        async function cancelTryonIfRunning() {
            tryonCancelRequested = true;
            try {
                if (tryonAbortController) tryonAbortController.abort();
            } catch (e) {}
            const taskId = tryonCurrentTaskId;
            tryonCurrentTaskId = '';
            if (taskId) {
                try {
                    await fetch(`${API_BASE}/api/virtual-tryon/task/${taskId}/cancel`, { method: 'POST', credentials: 'include' });
                } catch (e) {}
            }
            const loadingEl = document.getElementById('tryon-loading');
            const errorEl = document.getElementById('tryon-error');
            if (loadingEl) loadingEl.style.display = 'none';
            if (errorEl) {
                errorEl.textContent = '已取消';
                errorEl.style.display = 'block';
            }
            setTryonInProgress(false);
        }

        document.getElementById('cancel-tryon').addEventListener('click', async function() {
            await cancelTryonIfRunning();
        });
        
        // 选择衣服
        document.getElementById('garment-select').addEventListener('change', function() {
            const garmentId = this.value;
            if (garmentId) {
                const garment = wardrobeData.find(item => item.id == garmentId);
                if (garment) {
                    document.getElementById('garment-preview').innerHTML = `<img src="${garment.image_url || '/img/placeholder.svg'}" style="max-width: 100%; max-height: 200px; object-fit: cover; border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 4px;">`;
                }
            } else {
                document.getElementById('garment-preview').innerHTML = '';
            }
        });
        
        // 开始试衣
        document.getElementById('start-tryon').addEventListener('click', async function() {
            const fileInput = document.getElementById('person-image');
            const garmentId = document.getElementById('garment-select').value;
            
            if (!fileInput.files.length) {
                document.getElementById('tryon-error').textContent = '请上传人物照片';
                document.getElementById('tryon-error').style.display = 'block';
                return;
            }
            
            if (!garmentId) {
                document.getElementById('tryon-error').textContent = '请选择衣服';
                document.getElementById('tryon-error').style.display = 'block';
                return;
            }
            
            document.getElementById('tryon-error').style.display = 'none';
            document.getElementById('tryon-loading').style.display = 'block';
            document.getElementById('tryon-loading').textContent = '正在上传人物照片...';
            tryonCancelRequested = false;
            tryonCurrentTaskId = '';
            tryonAbortController = new AbortController();
            setTryonInProgress(true);
            
            try {
                // 上传人物照片
                const formData = new FormData();
                formData.append('file', fileInput.files[0]);
                
                const uploadResponse = await fetch(`${API_BASE}/api/upload/image`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData,
                    signal: tryonAbortController.signal
                });
                
                if (!uploadResponse.ok) {
                    throw new Error(`上传照片失败: HTTP ${uploadResponse.status}`);
                }
                
                const uploadResult = await uploadResponse.json();
                if (!uploadResult.success) {
                    throw new Error(uploadResult.message || '上传照片失败');
                }
                
                const personUrl = uploadResult.data.image_url;
                const garment = wardrobeData.find(item => item.id == garmentId);
                
                if (!garment) {
                    throw new Error('未找到选中的衣服');
                }
                
                // 调用虚拟试衣API
                document.getElementById('tryon-loading').textContent = '正在生成试衣效果（1/1）...';
                const tryonResponse = await fetch(`${API_BASE}/api/virtual-tryon`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        person_image_url: personUrl,
                        garment_image_url: garment.image_url || garment.image || '',
                        garment_type: garment.type === '上衣' ? 'top' : garment.type === '裤子' ? 'bottom' : 'top'
                    }),
                    signal: tryonAbortController.signal
                });
                
                if (!tryonResponse.ok) {
                    throw new Error(`虚拟试衣失败: HTTP ${tryonResponse.status}`);
                }
                
                const tryonResult = await tryonResponse.json().catch(() => ({}));
                if (!tryonResult || !tryonResult.success) {
                    throw new Error((tryonResult && tryonResult.message) || '虚拟试衣失败');
                }
                const data = tryonResult.data || {};
                const taskId = data.task_id || '';
                const immediateUrl = data.image_url || '';
                if (immediateUrl) {
                    document.getElementById('tryon-image').src = immediateUrl;
                    document.getElementById('tryon-result').style.display = 'block';
                    return;
                }
                if (!taskId) {
                    throw new Error('试衣接口未返回 task_id');
                }
                tryonCurrentTaskId = taskId;
                const finalUrl = await waitTryonTask(taskId, tryonAbortController.signal);
                if (!finalUrl) {
                    throw new Error('试衣未获得有效结果');
                }
                document.getElementById('tryon-image').src = finalUrl;
                document.getElementById('tryon-result').style.display = 'block';
            } catch (error) {
                const msg = (error && (error.name === 'AbortError' || String(error.message || '').includes('已取消'))) ? '已取消' : '试衣失败，请稍后重试';
                document.getElementById('tryon-error').textContent = msg;
                document.getElementById('tryon-error').style.display = 'block';
                console.error('虚拟试衣异常:', error);
            } finally {
                document.getElementById('tryon-loading').style.display = 'none';
                setTryonInProgress(false);
                tryonCurrentTaskId = '';
            }
        });
        
        // 下载试衣图片
        document.getElementById('download-tryon').addEventListener('click', function() {
            const imageUrl = document.getElementById('tryon-image').src;
            if (imageUrl) {
                const link = document.createElement('a');
                link.href = imageUrl;
                link.download = 'tryon-result.jpg';
                link.click();
            }
        });
        
        function buildTryonItemsFromSelected(selectedItems) {
            const mapType = (t) => {
                const s = String(t || '');
                if (s.includes('裙')) return 'dress';
                if (s.includes('裤')) return 'bottom';
                if (s.includes('鞋')) return null;
                return 'top';
            };
            const candidates = (Array.isArray(selectedItems) ? selectedItems : [])
                .map((it) => ({
                    garment_type: mapType(it.type),
                    garment_image_url: it.image_url || it.image || ''
                }))
                .filter((it) => it.garment_type && it.garment_image_url);

            const dress = candidates.find((it) => it.garment_type === 'dress');
            if (dress) return [dress];

            const top = candidates.find((it) => it.garment_type === 'top');
            const bottom = candidates.find((it) => it.garment_type === 'bottom');
            const out = [];
            if (top) out.push(top);
            if (bottom) out.push(bottom);
            return out.length ? out : candidates.slice(0, 2);
        }

        async function waitTryonTask(taskId, signal) {
            const start = Date.now();
            const timeoutMs = 10 * 60 * 1000;
            while (Date.now() - start < timeoutMs) {
                if (tryonCancelRequested) throw new Error('已取消');
                const resp = await fetch(`${API_BASE}/api/virtual-tryon/task/${taskId}`, { credentials: 'include', signal });
                const j = await resp.json().catch(() => ({}));
                if (!resp.ok || !j || !j.success) {
                    throw new Error((j && (j.message || j.error)) || '生成试衣效果失败，请稍后重试');
                }
                const data = j.data || {};
                const status = String(data.status || '').toLowerCase();
                if (status === 'completed') {
                    const url = data.final_image_url || data.image_url || data.imageUrl || '';
                    return url || '';
                }
                if (status === 'canceled') {
                    throw new Error('已取消');
                }
                if (status === 'failed') {
                    throw new Error((data && data.message) || '生成试衣效果失败，请稍后重试');
                }
                await new Promise(r => setTimeout(r, 1500));
            }
            throw new Error('生成试衣效果超时，请稍后重试');
        }

        async function tryonOutfitByIndex(outfitIndex) {
            document.querySelector('.tryon-section').scrollIntoView({ behavior: 'smooth' });
            const fileInput = document.getElementById('person-image');
            if (!fileInput || !fileInput.files || !fileInput.files.length) {
                alert('请先上传人物照片');
                return;
            }
            const outfits = recommendData && Array.isArray(recommendData.outfits) ? recommendData.outfits : [];
            const outfit = outfits[outfitIndex];
            if (!outfit || !Array.isArray(outfit.selected_items) || outfit.selected_items.length === 0) {
                alert('该方案没有可用的推荐单品，请重新生成推荐');
                return;
            }

            const items = buildTryonItemsFromSelected(outfit.selected_items);
            if (!items.length) {
                alert('该方案中没有可试穿的衣物（仅支持上衣/下装/裙装）');
                return;
            }

            document.getElementById('tryon-error').style.display = 'none';
            document.getElementById('tryon-loading').style.display = 'block';
            document.getElementById('tryon-loading').textContent = '正在上传人物照片...';
            tryonCancelRequested = false;
            tryonCurrentTaskId = '';
            tryonAbortController = new AbortController();
            setTryonInProgress(true);
            try {
                const formData = new FormData();
                formData.append('file', fileInput.files[0]);
                const uploadResp = await fetch(`${API_BASE}/api/upload/image`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData,
                    signal: tryonAbortController.signal
                });
                const uploadJson = await uploadResp.json().catch(() => ({}));
                if (!uploadResp.ok || !uploadJson || !uploadJson.success) {
                    throw new Error((uploadJson && (uploadJson.message || uploadJson.error)) || '上传人物照片失败，请稍后重试');
                }
                const personUrl = uploadJson.data && uploadJson.data.image_url ? uploadJson.data.image_url : '';
                if (!personUrl) {
                    throw new Error('上传人物照片成功但未返回可用URL');
                }

                const runStep = async (currentUrl, item, stepIndex, total) => {
                    const resp = await fetch(`${API_BASE}/api/virtual-tryon`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            person_image_url: currentUrl,
                            garment_image_url: item.garment_image_url,
                            garment_type: item.garment_type
                        }),
                        signal: tryonAbortController.signal
                    });
                    const result = await resp.json().catch(() => ({}));
                    if (!resp.ok || !result || !result.success) {
                        throw new Error((result && (result.message || result.error)) || '生成试衣效果失败，请稍后重试');
                    }
                    const data = result.data || {};
                    const immediateUrl = data.image_url || data.imageUrl || data.final_image_url || '';
                    if (immediateUrl) return immediateUrl;
                    const taskId = data.task_id || '';
                    if (!taskId) {
                        throw new Error('生成试衣效果失败，请稍后重试');
                    }
                    tryonCurrentTaskId = taskId;
                    document.getElementById('tryon-loading').textContent = `正在处理试衣效果（${stepIndex + 1}/${total}）...`;
                    const finalUrl = await waitTryonTask(taskId, tryonAbortController.signal);
                    if (!finalUrl) {
                        throw new Error('生成试衣效果失败，请稍后重试');
                    }
                    return finalUrl;
                };

                let currentUrl = personUrl;
                document.getElementById('tryon-loading').textContent = '正在生成试衣效果...';
                for (let i = 0; i < items.length; i++) {
                    if (tryonCancelRequested) throw new Error('已取消');
                    const item = items[i];
                    document.getElementById('tryon-loading').textContent = `正在试穿第 ${i + 1}/${items.length} 件...`;
                    currentUrl = await runStep(currentUrl, item, i, items.length);
                    if (currentUrl) {
                        document.getElementById('tryon-image').src = currentUrl;
                        document.getElementById('tryon-result').style.display = 'block';
                    }
                }

                if (!currentUrl) {
                    throw new Error('生成试衣效果失败，请稍后重试');
                }
                document.getElementById('tryon-image').src = currentUrl;
                document.getElementById('tryon-result').style.display = 'block';
                document.getElementById('tryon-loading').style.display = 'none';
            } catch (e) {
                console.error('换装失败:', e);
                let msg = (e && (e.name === 'AbortError' || String(e.message || '').includes('已取消'))) ? '已取消' : ((e && e.message) ? e.message : '生成试衣效果失败，请稍后重试');
                document.getElementById('tryon-error').textContent = msg;
                document.getElementById('tryon-error').style.display = 'block';
                document.getElementById('tryon-loading').style.display = 'none';
            } finally {
                document.getElementById('tryon-loading').style.display = 'none';
                setTryonInProgress(false);
                tryonCurrentTaskId = '';
            }
        }

        const outfitsContainer = document.getElementById('outfits-container');
        if (outfitsContainer) {
            outfitsContainer.addEventListener('click', async function(e) {
                const btn = e.target && e.target.closest ? e.target.closest('.outfit-tryon-btn') : null;
                if (!btn) return;
                const idx = Number(btn.getAttribute('data-outfit-index'));
                if (Number.isNaN(idx)) return;
                await tryonOutfitByIndex(idx);
            });
        }
        
        // 执行试衣逻辑的函数
        async function performTryon(fileInput, garmentId) {
            return new Promise(async (resolve) => {
                try {
                    document.getElementById('tryon-error').style.display = 'none';
                    document.getElementById('tryon-loading').style.display = 'block';
                    
                    // 上传人物照片
                    const formData = new FormData();
                    formData.append('file', fileInput.files[0]);
                    
                    const uploadResponse = await fetch(`${API_BASE}/api/upload/image`, {
                        method: 'POST',
                        credentials: 'include',
                        body: formData
                    });
                    
                    if (!uploadResponse.ok) {
                        throw new Error(`上传照片失败: HTTP ${uploadResponse.status}`);
                    }
                    
                    const uploadResult = await uploadResponse.json();
                    if (!uploadResult.success) {
                        throw new Error(uploadResult.message || '上传照片失败');
                    }
                    
                    const personUrl = uploadResult.data.image_url;
                    const garment = wardrobeData.find(item => item.id == garmentId);
                    
                    if (!garment) {
                        throw new Error('未找到选中的衣服');
                    }
                    
                    // 调用虚拟试衣API
                    const tryonResponse = await fetch(`${API_BASE}/api/virtual-tryon`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            person_image_url: personUrl,
                            garment_image_url: garment.image_url || garment.image || '',
                            garment_type: garment.type === '上衣' ? 'top' : garment.type === '裤子' ? 'bottom' : 'top'
                        })
                    });
                    
                    if (!tryonResponse.ok) {
                        throw new Error(`虚拟试衣失败: HTTP ${tryonResponse.status}`);
                    }
                    
                    const tryonResult = await tryonResponse.json().catch(() => ({}));
                    if (!tryonResult || !tryonResult.success) {
                        throw new Error((tryonResult && tryonResult.message) || '虚拟试衣失败');
                    }
                    const data = tryonResult.data || {};
                    const taskId = data.task_id || '';
                    const immediateUrl = data.image_url || '';
                    if (immediateUrl) {
                        document.getElementById('tryon-image').src = immediateUrl;
                        document.getElementById('tryon-result').style.display = 'block';
                    } else if (taskId) {
                        const finalUrl = await waitTryonTask(taskId);
                        if (!finalUrl) throw new Error('试衣未获得有效结果');
                        document.getElementById('tryon-image').src = finalUrl;
                        document.getElementById('tryon-result').style.display = 'block';
                    } else {
                        throw new Error('试衣接口未返回 task_id');
                    }
                } catch (error) {
                    document.getElementById('tryon-error').textContent = '试衣失败，请稍后重试';
                    document.getElementById('tryon-error').style.display = 'block';
                    console.error('虚拟试衣异常:', error);
                } finally {
                    document.getElementById('tryon-loading').style.display = 'none';
                    // 等待2秒让用户看到效果
                    setTimeout(resolve, 2000);
                }
            });
        }

        // ========== 场景滚轮选择（一定生效版）========== 
        document.addEventListener('DOMContentLoaded', function () { 
          const sceneSelect = document.getElementById('scene-select'); 

          if (!sceneSelect) return; 

          // 你的场景列表（必须和页面选项一致） 
          const scenes = [ 
            "日常通勤", 
            "商务会议", 
            "周末休闲", 
            "运动健身", 
            "约会出行", 
            "朋友聚会", 
            "正式晚宴", 
            "户外出行" 
          ]; 

          // 监听鼠标滚轮 
          sceneSelect.addEventListener('mousewheel', function (e) { 
            e.preventDefault(); // 禁止页面滚动 

            let currentIndex = scenes.indexOf(sceneSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 

            // 滚轮向下 → 下一个 
            if (e.deltaY > 0) { 
              currentIndex = (currentIndex + 1) % scenes.length; 
            } 
            // 滚轮向上 → 上一个 
            else { 
              currentIndex = (currentIndex - 1 + scenes.length) % scenes.length; 
            } 

            sceneSelect.value = scenes[currentIndex]; 
            sceneSelect.dispatchEvent(new Event('change')); 
          }); 

          // 火狐兼容 
          sceneSelect.addEventListener('wheel', function (e) { 
            e.preventDefault(); 

            let currentIndex = scenes.indexOf(sceneSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 

            if (e.deltaY > 0) { 
              currentIndex = (currentIndex + 1) % scenes.length; 
            } else { 
              currentIndex = (currentIndex - 1 + scenes.length) % scenes.length; 
            } 

            sceneSelect.value = scenes[currentIndex]; 
            sceneSelect.dispatchEvent(new Event('change')); 
          }); 
        }); 

        // ========== 目的滚轮选择 ========== 
        document.addEventListener('DOMContentLoaded', function () { 
          const purposeSelect = document.getElementById('purpose-select'); 
          if (!purposeSelect) return; 
          const purposes = ["日常办公", "商务会议", "休闲聚会", "运动健身", "约会出行"]; 
          purposeSelect.addEventListener('mousewheel', function (e) { 
            e.preventDefault(); 
            let currentIndex = purposes.indexOf(purposeSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 
            currentIndex = (currentIndex + (e.deltaY > 0 ? 1 : -1) + purposes.length) % purposes.length; 
            purposeSelect.value = purposes[currentIndex]; 
            purposeSelect.dispatchEvent(new Event('change')); 
          }); 
          purposeSelect.addEventListener('wheel', function (e) { 
            e.preventDefault(); 
            let currentIndex = purposes.indexOf(purposeSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 
            currentIndex = (currentIndex + (e.deltaY > 0 ? 1 : -1) + purposes.length) % purposes.length; 
            purposeSelect.value = purposes[currentIndex]; 
            purposeSelect.dispatchEvent(new Event('change')); 
          }); 
        }); 

        // ========== 风格偏好滚轮选择 ========== 
        document.addEventListener('DOMContentLoaded', function () { 
          const styleSelect = document.getElementById('style-select'); 
          if (!styleSelect) return; 
          const styles = ["简约", "复古", "街头", "日系", "美式", "韩系"]; 
          styleSelect.addEventListener('mousewheel', function (e) { 
            e.preventDefault(); 
            let currentIndex = styles.indexOf(styleSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 
            currentIndex = (currentIndex + (e.deltaY > 0 ? 1 : -1) + styles.length) % styles.length; 
            styleSelect.value = styles[currentIndex]; 
            styleSelect.dispatchEvent(new Event('change')); 
          }); 
          styleSelect.addEventListener('wheel', function (e) { 
            e.preventDefault(); 
            let currentIndex = styles.indexOf(styleSelect.value); 
            if (currentIndex === -1) currentIndex = 0; 
            currentIndex = (currentIndex + (e.deltaY > 0 ? 1 : -1) + styles.length) % styles.length; 
            styleSelect.value = styles[currentIndex]; 
            styleSelect.dispatchEvent(new Event('change')); 
          }); 
        });
    </script>

