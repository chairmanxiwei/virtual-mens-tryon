<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/renaissance-style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- 高德地图 JS API -->
    <link rel="stylesheet" href="https://a.amap.com/jsapi_demos/static/demo-center/css/demo-center.css" />
    <% if (amapJsApiKey) { %>
    <script src="https://webapi.amap.com/maps?v=2.0&key=<%= amapJsApiKey %>"></script>
    <% } %>
    <script src="https://webapi.amap.com/ui/1.1/main.js"></script>
    <!-- CDN 资源 -->
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <style>
        .ai-outfit-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 4rem 2rem;
        }
        
        .section-title {
            text-align: center;
            margin-bottom: 4rem;
        }
        
        .section-title h2 {
            font-size: 3.5rem;
            color: var(--accent-gold);
            margin-bottom: 1rem;
        }
        
        .section-title p {
            color: rgba(240, 240, 240, 0.6);
            font-style: italic;
        }
        
        .weather-section {
            background-color: var(--card-bg);
            border: 1px solid rgba(212, 175, 55, 0.1);
            padding: 2rem;
            margin-bottom: 3rem;
        }
        
        .weather-input {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        
        .weather-input input {
            flex: 1;
            padding: 1rem 1.5rem;
            background-color: #0f0f0f;
            border: 1px solid #444444;
            color: #ffffff;
            font-family: var(--font-body);
            font-size: 1.2rem;
            height: 60px;
            box-sizing: border-box;
            transition: border-color 0.3s ease;
        }
        
        .weather-input input::placeholder {
            font-size: 1.2rem;
            color: rgba(255, 255, 255, 0.7);
        }
        
        .weather-input input:focus, .weather-input input:hover {
            outline: none;
            border-color: #007bff;
        }
        
        .weather-result {
            margin-top: 1.5rem;
            padding: 20px;
            background-color: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
        }
        
        .weather-info {
            display: flex;
            gap: 2rem;
            align-items: center;
        }
        
        .weather-temp {
            font-size: 32px;
            font-weight: bold;
            color: #ffffff;
        }
        
        .weather-details {
            flex: 1;
        }
        
        .weather-details p {
            font-size: 16px;
            color: #e0e0e0;
            margin: 5px 0;
        }
        
        .btn-primary {
            background-color: #007bff;
            color: #ffffff;
            border: none;
            padding: 1rem 2rem;
            border-radius: 4px;
            font-size: 18px;
            font-weight: bold;
            height: 60px;
            box-sizing: border-box;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        
        .btn-primary:hover {
            background-color: #0069d9;
        }
        
        .btn-secondary {
            background-color: transparent;
            color: white;
            border: 1px solid white;
            padding: 1rem 2rem;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background-color: rgba(255, 255, 255, 0.1);
            border-color: white;
        }
        

        
        .recommend-section {
            background-color: var(--card-bg);
            border: 1px solid rgba(212, 175, 55, 0.1);
            padding: 2rem;
            margin-bottom: 3rem;
        }
        
        .recommend-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .form-group {
            margin-bottom: 0;
        }
        
        label {
            display: block;
            margin-bottom: 0.5rem;
            font-family: var(--font-body);
            font-size: 18px;
            font-weight: bold;
            color: #ffffff;
            position: relative;
            padding-left: 1.2rem;
        }
        
        label::before {
            content: "●";
            color: #ffd700;
            position: absolute;
            left: 0;
            top: 0;
            font-size: 12px;
        }
        
        select {
            width: 100%;
            padding: 1.2rem 1rem;
            background-color: #0f0f0f !important;
            border: 1px solid #444444;
            color: #ffffff !important;
            font-family: var(--font-body);
            font-size: 1.2rem;
            height: 60px;
            box-sizing: border-box;
            cursor: pointer;
            transition: border-color 0.3s ease;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            background-image: url('data:image/svg+xml;utf8,<svg fill="%23ffffff" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/><path d="M0 0h24v24H0z" fill="none"/></svg>');
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 16px;
            z-index: 1000;
            position: relative;
            overflow: visible;
        }
        
        select:focus, select:hover {
            outline: none;
            border-color: #007bff;
        }
        
        select option {
            background-color: #222222;
            color: #ffffff;
        }
        
        select:focus {
            color: #ffffff !important;
        }
        
        select option:checked {
            background-color: #007bff !important;
            color: #ffffff !important;
        }
        
        .recommend-result {
            margin-top: 2rem;
            padding: 2rem;
            background-color: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
        }
        
        .recommend-result h4 {
            font-size: 20px;
            font-weight: bold;
            color: #ffd700;
            margin-bottom: 1rem;
        }
        
        .reason-section {
            margin-top: 2rem;
        }
        
        .reason-section h4 {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 1rem;
            color: #ffd700;
        }
        
        .reason-section p {
            font-size: 18px;
            line-height: 1.8;
            color: #f0f0f0;
        }

        .outfit-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .outfit-card {
            border: 1px solid rgba(240,240,240,0.12);
            border-radius: 10px;
            overflow: hidden;
            background: rgba(10,10,10,0.6);
        }

        .outfit-card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
        }

        .outfit-card .meta {
            padding: 0.8rem 0.9rem;
        }

        .outfit-card .name {
            color: #fff;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }

        .outfit-card .sub {
            color: rgba(240,240,240,0.7);
            font-size: 0.85rem;
        }

        @media (max-width: 900px) {
            .outfit-cards { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 560px) {
            .outfit-cards { grid-template-columns: 1fr; }
        }
        
        .missing-items {
            margin-top: 1.5rem;
            padding: 1rem;
            background-color: rgba(114, 47, 55, 0.1);
            border: 1px solid rgba(114, 47, 55, 0.3);
        }
        
        .missing-items h4 {
            font-size: 1rem;
            margin-bottom: 0.5rem;
            color: var(--accent-red);
        }
        
        .missing-items p {
            color: var(--text-color);
        }

        .outfits-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.2rem;
            margin-top: 1.2rem;
        }

        .outfit-plan {
            border: 1px solid rgba(212, 175, 55, 0.12);
            border-radius: 12px;
            background: rgba(10,10,10,0.55);
            overflow: hidden;
        }

        .outfit-plan-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.1rem;
            background: rgba(212, 175, 55, 0.06);
            border-bottom: 1px solid rgba(212, 175, 55, 0.12);
        }

        .outfit-plan-title {
            color: #ffd700;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .outfit-plan-body {
            padding: 1rem 1.1rem 1.2rem;
        }

        .outfit-plan-reason {
            color: rgba(240,240,240,0.9);
            font-size: 1rem;
            line-height: 1.8;
            margin: 0.6rem 0 0.8rem;
            white-space: pre-wrap;
        }

        .outfit-plan-actions {
            margin-top: 1rem;
            display: flex;
            justify-content: flex-end;
        }

        .outfit-tryon-btn {
            border-color: rgba(212, 175, 55, 0.6);
        }

        .missing-type-cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.9rem;
            margin-top: 1rem;
        }

        .missing-type-card {
            border: 1px solid rgba(240,240,240,0.12);
            border-radius: 12px;
            background: rgba(10,10,10,0.55);
            overflow: hidden;
        }

        .missing-type-card .head {
            padding: 0.75rem 0.85rem;
            background: rgba(114, 47, 55, 0.12);
            border-bottom: 1px solid rgba(114, 47, 55, 0.22);
            color: var(--accent-red);
            font-weight: 800;
        }

        .missing-type-card .body {
            padding: 0.85rem;
        }

        .missing-type-card .example {
            color: #fff;
            font-weight: 700;
            margin-bottom: 0.4rem;
        }

        .missing-type-card .reason {
            color: rgba(240,240,240,0.78);
            font-size: 0.9rem;
            line-height: 1.6;
            margin-bottom: 0.7rem;
        }

        .missing-type-card .links a {
            display: inline-block;
            color: rgba(212, 175, 55, 0.9);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
        }

        @media (max-width: 900px) {
            .missing-type-cards { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 560px) {
            .missing-type-cards { grid-template-columns: 1fr; }
        }

        .missing-products {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .missing-product {
            border: 1px solid rgba(240,240,240,0.12);
            border-radius: 10px;
            overflow: hidden;
            background: rgba(10,10,10,0.6);
        }

        .missing-product a {
            display: block;
            color: inherit;
            text-decoration: none;
        }

        .missing-product img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            display: block;
        }

        .missing-product .meta {
            padding: 0.8rem 0.9rem;
        }

        .missing-product .name {
            color: #fff;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }

        .missing-product .sub {
            color: rgba(240,240,240,0.7);
            font-size: 0.85rem;
        }

        @media (max-width: 900px) {
            .missing-products { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 560px) {
            .missing-products { grid-template-columns: 1fr; }
        }
        
        .tryon-section {
            background-color: var(--card-bg);
            border: 1px solid rgba(212, 175, 55, 0.1);
            padding: 2rem;
        }
        
        .tryon-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .upload-zone {
            border: 1px dashed rgba(240, 240, 240, 0.3);
            padding: 3rem 2rem;
            text-align: center;
            transition: border-color 0.3s ease;
        }
        
        .upload-zone h4 {
            color: white;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }
        
        .upload-zone:hover {
            border-color: var(--accent-gold);
        }
        
        .upload-zone input[type="file"] {
            display: none;
        }
        
        .tryon-result {
            margin-top: 2rem;
            text-align: center;
        }
        
        .tryon-result img {
            max-width: 100%;
            max-height: 500px;
            border: 1px solid rgba(212, 175, 55, 0.3);
        }
        
        .loading {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            color: var(--accent-gold);
        }
        
        .error {
            color: var(--accent-red);
            margin-top: 0.5rem;
            font-size: 0.9rem;
        }
    </style>
</head>
<body class="custom-cursor-enabled">
    <!-- Custom Cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <nav class="nav-overlay">
        <div class="brand">虚拟男装</div>
        <div class="nav-links">
            <a href="/dashboard" class="nav-item">首页</a>
            <a href="/wardrobe" class="nav-item">衣橱</a>
            <a href="/ai-outfit" class="nav-item active">AI搭配</a>
            <a href="/virtual-tryon" class="nav-item">虚拟试穿</a>
            <a href="/admin/outfits" class="nav-item">管理</a>   
            <a href="/logout" class="nav-item">登出</a>
        </div>
    </nav>
    
    <div class="ai-outfit-container">
        <div class="hero" style="min-height: 30vh; padding-top: 10vh;">
            <h1 class="hero-title reveal-text">
                <span>AI 穿搭推荐</span>
            </h1>
            <p class="hero-subtitle">根据天气、场景和个人风格，为您推荐最合适的穿搭方案</p>
        </div>
        
        <!-- 天气查询部分 -->
        <div class="weather-section">
            <h3>天气查询</h3>
            <div class="weather-input">
                <input type="text" id="location-input" placeholder="请输入所在地，如：北京市朝阳区">
                <button class="btn btn-primary" id="weather-btn">查询天气</button>
            </div>
            <div id="weather-result" class="weather-result" style="display: none;">
                <div class="weather-info">
                    <div class="weather-temp" id="weather-temp">--°C</div>
                    <div class="weather-details">
                        <p id="weather-type">--</p>
                        <p id="weather-wind">风速：--</p>
                        <p id="weather-humidity">湿度：--</p>
                    </div>
                </div>
            </div>
            <div id="weather-error" class="error" style="display: none;"></div>
        </div>
        

        
        <!-- 穿搭推荐部分 -->
        <div class="recommend-section">
            <h3>穿搭推荐</h3>
            <div class="outfit-row"> 
              <div class="outfit-field"> 
                <label class="field-label">场景</label> 
                <select id="scene-select" class="outfit-select"> 
                  <option value="日常通勤">日常通勤</option> 
                  <option value="商务会议">商务会议</option> 
                  <option value="周末休闲">周末休闲</option> 
                  <option value="运动健身">运动健身</option> 
                  <option value="约会出行">约会出行</option> 
                  <option value="朋友聚会">朋友聚会</option> 
                  <option value="正式晚宴">正式晚宴</option> 
                  <option value="户外出行">户外出行</option> 
                </select> 
              </div> 
              <div class="outfit-field"> 
                <label class="field-label">目的</label> 
                <select id="purpose-select" class="outfit-select"> 
                  <option value="日常办公">日常办公</option> 
                  <option value="商务会议">商务会议</option> 
                  <option value="休闲聚会">休闲聚会</option> 
                  <option value="运动健身">运动健身</option> 
                  <option value="约会出行">约会出行</option> 
                </select> 
              </div> 
              <div class="outfit-field"> 
                <label class="field-label">风格偏好</label> 
                <select id="style-select" class="outfit-select"> 
                  <option value="简约">简约</option> 
                  <option value="复古">复古</option> 
                  <option value="街头">街头</option> 
                  <option value="日系">日系</option> 
                  <option value="美式">美式</option> 
                  <option value="韩系">韩系</option> 
                </select> 
              </div> 
            </div>
            <button class="btn btn-primary" id="recommend-btn">生成推荐</button>
            <div id="recommend-loading" class="loading" style="display: none;">生成中...</div>
            <div id="recommend-result" class="recommend-result" style="display: none;">
                <div id="outfits-container" class="outfits-container"></div>
                <div id="missing-items" class="missing-items" style="display: none;">
                    <h4>需补充</h4>
                    <p id="missing-text"></p>
                    <div id="missing-type-cards" class="missing-type-cards"></div>
                    <div id="missing-products" class="missing-products"></div>
                </div>
            </div>
            <div id="recommend-error" class="error" style="display: none;"></div>
        </div>
        
        <!-- 虚拟试衣部分 -->
        <div class="tryon-section">
            <h3>虚拟试衣</h3>
            <div class="tryon-form">
                <div class="upload-zone">
                    <h4>上传人物照片</h4>
                    <input type="file" id="person-image" accept="image/*">
                    <button class="btn btn-secondary" id="select-person">选择照片</button>
                    <div id="person-preview" style="margin-top: 1rem;"></div>
                </div>
                <div class="upload-zone">
                    <h4>自主选择衣服</h4>
                    <select id="garment-select">
                        <option value="">请选择衣服</option>
                    </select>
                    <div id="garment-preview" style="margin-top: 1rem;"></div>
                </div>
            </div>
            <button class="btn btn-primary" id="start-tryon">开始试衣</button>
            <button class="btn btn-secondary" id="cancel-tryon" style="display: none; margin-left: 0.5rem;">取消</button>
            <div id="tryon-loading" class="loading" style="display: none;">生成中...</div>
            <div id="tryon-result" class="tryon-result" style="display: none;">
                <h4>试衣效果</h4>
                <img id="tryon-image" src="" alt="试衣效果">
                <button class="btn btn-secondary" id="download-tryon" style="margin-top: 1rem;">下载图片</button>
            </div>
            <div id="tryon-error" class="error" style="display: none;"></div>
        </div>
    </div>
    
    <script>
        const API_BASE = (window.AI_API_BASE || window.location.origin).replace(/\/+$/, '');
        let weatherData = null;
        let wardrobeData = [];
        let recommendData = null;
        let tryonAbortController = null;
        let tryonCancelRequested = false;
        let tryonCurrentTaskId = '';
        console.log('API_BASE:', API_BASE);
        
        // 页面加载后自动静默加载衣橱数据（无感知）
        window.addEventListener('DOMContentLoaded', async function() {
            const fetchWithRetry = async (url, options, retries = 3, delay = 1000) => {
                for (let i = 0; i < retries; i++) {
                    try {
                        const response = await fetch(url, options);
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return await response.json();
                    } catch (error) {
                        console.warn(`衣橱数据加载失败 (${i + 1}/${retries})`, error.message);
                        if (i < retries - 1) {
                            await new Promise(resolve => setTimeout(resolve, delay));
                        } else {
                            throw error;
                        }
                    }
                }
            };

            try {
                const result = await fetchWithRetry(`${API_BASE}/api/wardrobe/clothes`, { credentials: 'include' });
                if (result && result.success && Array.isArray(result.data)) {
                    wardrobeData = result.data;
                    populateGarmentSelect(); // 为试衣环节准备衣服列表
                    console.log('衣橱数据加载成功:', wardrobeData.length, '件衣服');
                } else {
                    wardrobeData = [];
                    console.error('衣橱数据格式错误：', result);
                }
            } catch (error) {
                console.error('衣橱数据自动加载异常:', error);
                // 加载失败时显示友好提示
                showTopNotice('衣橱数据加载失败，部分功能可能受限');
            }
        });

        // 天气查询
        document.getElementById('weather-btn').addEventListener('click', async function() {
            const location = document.getElementById('location-input').value.trim();
            if (!location) {
                document.getElementById('weather-error').textContent = '请输入所在地';
                document.getElementById('weather-error').style.display = 'block';
                return;
            }
            
            document.getElementById('weather-error').style.display = 'none';
            
            try {
                const response = await fetch(`${API_BASE}/api/weather/query`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ address: location })
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                if (result.success) {
                    weatherData = result.data;
                    document.getElementById('weather-temp').textContent = `${weatherData.temperature || '--'}°C`;
                    document.getElementById('weather-type').textContent = `天气：${weatherData.weather || weatherData.weather_type || '--'}`;
                    document.getElementById('weather-wind').textContent = `风速：${weatherData.wind || weatherData.wind_speed || '--'}`;
                    document.getElementById('weather-humidity').textContent = `湿度：${weatherData.humidity || '--'}%`;
                    document.getElementById('weather-result').style.display = 'block';
                    console.log('天气查询成功:', weatherData);
                } else {
                    document.getElementById('weather-error').textContent = result.message || '天气查询失败，请检查后端服务';
                    document.getElementById('weather-error').style.display = 'block';
                    console.error('天气查询失败:', result.message);
                }
            } catch (error) {
                document.getElementById('weather-error').textContent = '天气查询失败：后端服务未启动，请检查 Python 服务';
                document.getElementById('weather-error').style.display = 'block';
                console.error('天气查询异常:', error);
            }
        });
        
        // 填充衣服选择下拉框（试衣环节用）
