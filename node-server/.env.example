# =============================================================================
# 虚拟男装智能穿搭系统 - 环境变量配置示例
# =============================================================================
# 请复制此文件为 .env 并填入实际配置值
# 重要：.env 文件包含敏感信息，严禁提交至版本控制系统！
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
# 端口号（默认：3000）
PORT=3000

# 运行环境：development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# 数据库配置（MySQL）
# -----------------------------------------------------------------------------
# 数据库主机地址
DB_HOST=localhost

# 数据库端口（默认：3306）
DB_PORT=3306

# 数据库用户名
DB_USER=your_db_user

# 数据库密码（重要：请使用强密码并妥善保管）
DB_PASS=your_db_password

# 数据库名称
DB_NAME=virtual_fashion

# -----------------------------------------------------------------------------
# 会话配置
# -----------------------------------------------------------------------------
# 会话密钥（重要：必须至少32字节，建议使用随机字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_at_least_32_bytes_long

# Session Cookie 配置
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# CORS 配置
# -----------------------------------------------------------------------------
# 允许的跨域来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# AI 后端服务配置
# -----------------------------------------------------------------------------
# AI 后端基础 URL（Python 服务地址）
AI_BACKEND_BASE_URL=http://127.0.0.1:8000

# AI Agent API URL（如与 AI_BACKEND_BASE_URL 不同）
# AI_AGENT_API_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# 阿里云 OSS 配置（用于文件存储）
# -----------------------------------------------------------------------------
# 获取方式：阿里云控制台 -> 对象存储 OSS -> 访问密钥
OSS_ACCESS_KEY_ID=your_oss_access_key_id

OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# OSS Bucket 名称
OSS_BUCKET_NAME=your_bucket_name

# OSS 端点（如：oss-cn-shanghai.aliyuncs.com）
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# -----------------------------------------------------------------------------
# 高德地图 API 配置
# -----------------------------------------------------------------------------
# 获取方式：高德开放平台 -> 应用管理 -> Web服务 API 密钥
AMAP_JS_API_KEY=your_amap_js_api_key

# -----------------------------------------------------------------------------
# GitHub OAuth 配置（用于登录功能）
# -----------------------------------------------------------------------------
# 获取方式：GitHub Settings -> Developer settings -> OAuth Apps -> New OAuth App
# 回调 URL设置为：${PUBLIC_BASE_URL}/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id

GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth 回调 URL
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# -----------------------------------------------------------------------------
# LLM（大型语言模型）配置
# -----------------------------------------------------------------------------
# LLM 提供者：ollama | dashscope | openai
LLM_PROVIDER=ollama

# Ollama 服务地址（当 LLM_PROVIDER=ollama 时使用）
OLLAMA_URL=http://localhost:11434

# Ollama 模型名称
LLM_MODEL=llama3

# -----------------------------------------------------------------------------
# DashScope API 配置（阿里云通义千问）
# -----------------------------------------------------------------------------
# 获取方式：阿里云百炼平台 -> API-KEY 管理
DASHSCOPE_API_KEY=your_dashscope_api_key

# 单独设置 LLM API Key（可选）
# DASHSCOPE_LLM_API_KEY=your_dashscope_llm_api_key

# 单独设置虚拟试衣 API Key（可选）
# DASHSCOPE_TRYON_API_KEY=your_dashscope_tryon_api_key

# 文生图 API Key（可选）
# DASHSCOPE_WANX_API_KEY=your_dashscope_wanx_api_key

# Qwen 模型名称（可选）
# QWEN_MODEL=qwen-turbo

# -----------------------------------------------------------------------------
# 虚拟试衣服务配置
# -----------------------------------------------------------------------------
# CatVTon 服务地址
CATVTON_URL=http://localhost:8000

# CatVTon 函数索引（通常为 0）
CATVTON_FN_INDEX=0

# -----------------------------------------------------------------------------
# PIFuHD 配置（3D 人体重建）
# -----------------------------------------------------------------------------
# PIFuHD 根目录
# PIFUHD_ROOT=/path/to/pifuhd

# Python 解释器路径
PIFUHD_PYTHON=python

# -----------------------------------------------------------------------------
# 密码哈希配置（管理员和测试用户）
# -----------------------------------------------------------------------------
# 使用 bcryptjs 哈希后的密码
# 生成方式：node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$your_admin_password_hash

USER_PASSWORD_HASH=$2a$10$your_user_password_hash

# -----------------------------------------------------------------------------
# 公共基础 URL
# -----------------------------------------------------------------------------
# 用于生成回调链接等场景
PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 调试配置（生产环境建议关闭）
# -----------------------------------------------------------------------------
DEBUG_HTTP=0
DEBUG_SESSION=0
DEBUG_CSP=0
DEBUG_AUTH=0

# -----------------------------------------------------------------------------
# 请求体大小限制
# -----------------------------------------------------------------------------
APP_MAX_BODY_SIZE=10mb

# -----------------------------------------------------------------------------
# 文件上传配置
# -----------------------------------------------------------------------------
# 最大上传文件大小（字节）
UPLOAD_MAX_BYTES=5242880

# Python 解释器路径
PYTHON_PATH=python
