# =============================================================================
# 虚拟男装智能穿搭系统 - Python 后端环境变量配置示例
# =============================================================================
# 请复制此文件为 .env 并填入实际配置值
# 重要：.env 文件包含敏感信息，严禁提交至版本控制系统！
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库配置（MySQL）
# -----------------------------------------------------------------------------
# 数据库主机地址
DB_HOST=localhost

# 数据库端口（默认：3306）
DB_PORT=3306

# 数据库用户名
DB_USER=your_db_user

# 数据库密码（重要：请使用强密码并妥善保管）
DB_PASS=your_db_password

# 数据库名称
DB_NAME=virtual_fashion

# -----------------------------------------------------------------------------
# 应用服务器配置
# -----------------------------------------------------------------------------
# 服务器监听地址
APP_HOST=127.0.0.1

# 服务器监听端口
APP_PORT=8000

# 公共基础 URL（用于生成回调链接等）
PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# 内部服务地址配置
# -----------------------------------------------------------------------------
# 内部服务访问地址（用于服务间通信）
INTERNAL_FETCH_HOSTS=localhost,127.0.0.1,::1

# -----------------------------------------------------------------------------
# 数据库连接超时配置
# -----------------------------------------------------------------------------
DB_CONNECT_TIMEOUT=5
DB_READ_TIMEOUT=20
DB_WRITE_TIMEOUT=20

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 天气 API 配置
# -----------------------------------------------------------------------------
# 高德地图天气 API Key
# 获取方式：高德开放平台 -> Web服务 API
AMAP_API_KEY=your_amap_api_key

# 天气缓存 TTL（秒）
WEATHER_CACHE_TTL=600

# -----------------------------------------------------------------------------
# 阿里云 OSS 配置（用于文件存储）
# -----------------------------------------------------------------------------
# 获取方式：阿里云控制台 -> 对象存储 OSS -> 访问密钥
OSS_ACCESS_KEY_ID=your_oss_access_key_id

OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# OSS Bucket 名称
OSS_BUCKET_NAME=your_bucket_name

# OSS 端点（如：oss-cn-shanghai.aliyuncs.com）
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# OSS 公共基础 URL（可选）
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-shanghai.aliyuncs.com

# -----------------------------------------------------------------------------
# DashScope API 配置（阿里云通义千问）
# -----------------------------------------------------------------------------
# 获取方式：阿里云百炼平台 -> API-KEY 管理
# 支持多个环境变量优先级：DASHSCOPE_LLM_API_KEY > DASHSCOPE_API_KEY > ALIYUN_API_KEY
DASHSCOPE_API_KEY=your_dashscope_api_key

# 单独设置 LLM API Key（可选，覆盖 DASHSCOPE_API_KEY）
# DASHSCOPE_LLM_API_KEY=your_dashscope_llm_api_key

# 单独设置虚拟试衣 API Key（可选）
# DASHSCOPE_TRYON_API_KEY=your_dashscope_tryon_api_key

# Qwen 模型名称（可选）
# QWEN_MODEL=qwen-turbo

# LLM 超时配置（秒）
LLM_TIMEOUT=10

# LLM 最大重试次数
LLM_MAX_TOTAL_ATTEMPTS=3

# -----------------------------------------------------------------------------
# 文生图配置
# -----------------------------------------------------------------------------
# 主模型（逗号分隔）
TEXT2IMAGE_PRIMARY_MODELS=wanx-t2i-pro

# 备选模型（逗号分隔）
TEXT2IMAGE_SECONDARY_MODELS=

# 所有可用模型（逗号分隔，设置后覆盖 primary 和 secondary）
TEXT2IMAGE_MODELS=

# 是否启用模型混合
TEXT2IMAGE_MIX_ENABLED=1

# 文生图缓存 TTL（秒）
TEXT2IMAGE_CACHE_TTL=86400

# 文生图并发数
TEXT2IMAGE_CONCURRENCY=1

# -----------------------------------------------------------------------------
# 虚拟试衣配置
# -----------------------------------------------------------------------------
TRYON_MAX_ATTEMPTS=2
TRYON_CREATE_READ_TIMEOUT=60
TRYON_QUERY_READ_TIMEOUT=30
TRYON_MAX_WAIT_SECONDS=180
TRYON_POLL_INTERVAL=3

# -----------------------------------------------------------------------------
# CORS 配置
# -----------------------------------------------------------------------------
# 允许的跨域来源
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# 调试配置
# -----------------------------------------------------------------------------
# 启用 DashScope 调试日志
# DEBUG_DASHSCOPE=1

# 调试缺失图片任务
# DEBUG_MISSING_IMAGE=1

# -----------------------------------------------------------------------------
# 缺失图片任务配置
# -----------------------------------------------------------------------------
MISSING_IMAGE_TASK_MAX_SECONDS=140
MISSING_IMAGE_TASK_LIMIT=12

# -----------------------------------------------------------------------------
# 性能配置
# -----------------------------------------------------------------------------
SLOW_REQUEST_MS=2000

# -----------------------------------------------------------------------------
# 衣橱图片基础 URL
# -----------------------------------------------------------------------------
# WARDROBE_IMAGE_BASE_URL=http://localhost:8000
