# ===============================
# 虚拟男装 - 环境变量模板（示例）
# 复制为 .env.development / .env.production 后再填写真实值
# ===============================

# ===== 运行环境 =====
NODE_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://127.0.0.1:3000
AI_BACKEND_BASE_URL=http://127.0.0.1:8000
AI_AGENT_API_URL=http://127.0.0.1:8000
APP_HOST=0.0.0.0
APP_PORT=8000
PORT=3000

# ===== 1) 高德地图 API =====
AMAP_API_KEY=your_amap_web_service_key
AMAP_JS_API_KEY=your_amap_js_api_key
AMAP_KEY=your_amap_compat_key

# ===== 2) 阿里云大模型（DashScope）=====
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_LLM_API_KEY=your_dashscope_llm_api_key
DASHSCOPE_TRYON_API_KEY=your_dashscope_tryon_api_key
DASHSCOPE_IMAGE_API_KEY=your_dashscope_image_api_key
DASHSCOPE_WANX_API_KEY=your_dashscope_wanx_api_key
ALIYUN_API_KEY=your_aliyun_api_key
QWEN_MODEL=qwen-turbo
LLM_TIMEOUT=15
LLM_MAX_TOTAL_ATTEMPTS=3
LLM_PROVIDER=ollama
LLM_URL=http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434
LLM_MODEL=llama3

# ===== 3) 阿里云 OSS =====
OSS_BUCKET_NAME=virtual-tryon-final
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_PUBLIC_BASE_URL=https://virtual-tryon-final.oss-cn-shanghai.aliyuncs.com/

# ===== 4) MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=virtual_man
DB_PASS=replace_with_secure_password
DB_NAME=virtual_man_fashion
DB_CONNECT_TIMEOUT=5
DB_READ_TIMEOUT=20
DB_WRITE_TIMEOUT=20

# ===== 5) 后端/网关联动 =====
FRONTEND_ORIGIN=http://127.0.0.1:3000
CORS_ORIGINS=http://127.0.0.1:3000
WARDROBE_IMAGE_BASE_URL=http://127.0.0.1:3000
INTERNAL_FETCH_HOSTS=localhost,127.0.0.1,::1
SLOW_REQUEST_MS=2000
WEATHER_CACHE_TTL=600

# ===== 6) 虚拟试衣模式与任务控制 =====
TRYON_CHAIN_ENABLED=1
TRYON_ALLOW_LOCAL_FALLBACK=0
TRYON_MAX_ATTEMPTS=2
TRYON_CREATE_READ_TIMEOUT=60
TRYON_QUERY_READ_TIMEOUT=30
TRYON_MAX_WAIT_SECONDS=180
TRYON_TASK_MAX_WAIT_SECONDS=600
TRYON_POLL_INTERVAL=3
MISSING_IMAGE_TASK_LIMIT=12
MISSING_IMAGE_TASK_MAX_SECONDS=140
TEXT2IMAGE_CONCURRENCY=1
TEXT2IMAGE_CACHE_TTL=86400
TEXT2IMAGE_POLL_TIMES=60
TEXT2IMAGE_POLL_INTERVAL=2.0
TEXT2IMAGE_MIX_ENABLED=1
TEXT2IMAGE_PRIMARY_MODELS=wanx2.1-t2i-turbo
TEXT2IMAGE_SECONDARY_MODELS=wanx2.0-t2i
TEXT2IMAGE_MODELS=
CATVTON_URL=
CATVTON_FN_INDEX=0

# ===== 7) 前端 / 登录系统安全 =====
SESSION_SECRET=replace_with_32bytes_random_secret
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=lax
CSRF_COOKIE_DOMAIN=
CSRF_COOKIE_SAMESITE=lax
USER_ID_COOKIE_DOMAIN=
USER_ID_COOKIE_SAMESITE=lax
DEBUG_HTTP=0
DEBUG_SESSION=0
DEBUG_CSP=0
DEBUG_AUTH=0
DEBUG_MISSING_IMAGE=0
DEBUG_DASHSCOPE=0
UPLOAD_MAX_BYTES=5242880
APP_MAX_BODY_SIZE=10mb
DEMO_OUTFIT_IMAGE_URL=/img/placeholder.svg

# ===== 第三方登录 =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# ===== 证书与反向代理（部署脚本使用）=====
DOMAIN=cls.troby.cn
TLS_CERT_PATH=/etc/letsencrypt/live/cls.troby.cn/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/cls.troby.cn/privkey.pem
NGINX_SERVER_NAME=cls.troby.cn
